# Managed by github.com/lohanidamodar/gitpod-dotfiles (setup.sh -> ~/.gitconfig).
# Public-safe: NO personal identity here. Your name/email live in the untracked
# ~/.gitconfig.local, pulled in by the include below (setup.sh seeds it from
# whatever identity you already had).

[include]
    path = ~/.gitconfig.local

[init]
    defaultBranch = main

[pull]
    rebase = false

[push]
    autoSetupRemote = true

[fetch]
    prune = true

[core]
    # Prefer git-delta (see INSTALL_SHELL_UTILS); fall back to less, then cat.
    # Git runs this via a shell, so probe with `command -v` first — a plain
    # `delta || less -R` prints "delta: command not found" on every diff when a
    # tool is missing; the guards degrade silently instead.
    pager = if command -v delta >/dev/null 2>&1; then delta; elif command -v less >/dev/null 2>&1; then less -R; else cat; fi
    autocrlf = input
    # editor is intentionally unset: git honours $EDITOR/$VISUAL, which the
    # deployed ~/.zshrc points at an editor that actually exists.

[interactive]
    diffFilter = if command -v delta >/dev/null 2>&1; then delta --color-only; else cat; fi

[delta]
    navigate = true
    line-numbers = true
    side-by-side = false

[merge]
    conflictstyle = zdiff3

[diff]
    colorMoved = default
    algorithm = histogram

[color]
    ui = auto

[rerere]
    enabled = true

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true

[alias]
    st = status -sb
    co = checkout
    cob = checkout -b
    br = branch
    ci = commit
    cm = commit -m
    amend = commit --amend --no-edit
    lg = log --oneline --graph --decorate --all
    last = log -1 HEAD --stat
    unstage = reset HEAD --
    undo = reset --soft HEAD~1
    wip = !git add -A && git commit -m wip
    aliases = config --get-regexp ^alias\\.
